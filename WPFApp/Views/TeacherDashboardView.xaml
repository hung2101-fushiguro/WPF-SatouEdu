<UserControl x:Class="WPFApp.Views.TeacherDashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent" FontFamily="Segoe UI">

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <Grid Margin="10,0,10,20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="0,0,0,30">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" VerticalAlignment="Bottom">
                    <TextBlock Text="Quản lý Lớp học" FontSize="36" FontWeight="ExtraBlack" Foreground="#191c1d" Margin="0,0,0,10"/>
                    <TextBlock Text="Tổ chức, chỉnh sửa và quản lý các lớp học của bạn từ một trung tâm duy nhất." FontSize="16" Foreground="#6b7280"/>
                </StackPanel>

                <Button Grid.Column="1"
        Command="{Binding AddClassCommand}"
        MinHeight="45"
        Padding="20,10"
        VerticalAlignment="Bottom"
        Cursor="Hand"
        BorderThickness="0">

                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="btnBg" CornerRadius="12" Background="#66FF33">
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="15"
                                      ShadowDepth="4"
                                      Color="#66FF33"
                                      Opacity="0.3"/>
                                </Border.Effect>

                                <StackPanel Orientation="Horizontal"
                            VerticalAlignment="Center"
                            HorizontalAlignment="Center">

                                    <!-- Icon -->
                                    <TextBlock Text="&#xE710;"
                               FontFamily="Segoe MDL2 Assets"
                               FontSize="16"
                               Foreground="#042100"
                               FontWeight="Bold"
                               Margin="0,0,10,0"/>

                                    <!-- Text -->
                                    <TextBlock Text="Tạo Lớp Mới"
                               FontSize="14"
                               FontWeight="Bold"
                               Foreground="#042100"/>
                                </StackPanel>
                            </Border>

                            <!-- Hover effect -->
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="btnBg" Property="Background" Value="#5BE62E"/>
                                </Trigger>

                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="btnBg" Property="RenderTransform">
                                        <Setter.Value>
                                            <ScaleTransform ScaleX="0.97" ScaleY="0.97"/>
                                        </Setter.Value>
                                    </Setter>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>

            <ItemsControl Grid.Row="1" ItemsSource="{Binding Classes}" Margin="0,0,0,40">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <UniformGrid Columns="3" VerticalAlignment="Top"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Background="#ffffff" CornerRadius="25" Margin="0,0,20,20" Padding="20" BorderBrush="#f3f4f5" BorderThickness="1">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="30" ShadowDepth="8" Color="Black" Opacity="0.04"/>
                            </Border.Effect>
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="160"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <Border Grid.Row="0" CornerRadius="15" Margin="0,0,0,20">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="#004d64" Offset="0"/>
                                            <GradientStop Color="#65d3ff" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                    <Border HorizontalAlignment="Left" VerticalAlignment="Top" Margin="15" Background="{Binding StatusColor}" CornerRadius="12" Padding="12,4">
                                        <TextBlock Text="{Binding Status}" Foreground="White" FontSize="10" FontWeight="Bold" Typography.Capitals="AllSmallCaps"/>
                                    </Border>
                                </Border>

                                <TextBlock Grid.Row="1" Text="{Binding ClassName}" FontSize="18" FontWeight="Bold" Foreground="#191c1d" Margin="0,0,0,10"/>
                                <TextBlock Grid.Row="2" Text="{Binding Description}" FontSize="13" Foreground="#6b7280" TextWrapping="Wrap" Margin="0,0,0,20" MinHeight="40"/>

                                <StackPanel Grid.Row="3" Margin="0,0,0,20">
                                    <Grid Margin="0,0,0,5">
                                        <TextBlock Text="SĨ SỐ" FontSize="11" FontWeight="Bold" Foreground="#9ca3af" HorizontalAlignment="Left"/>
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                            <TextBlock Text="{Binding StudentCount}" FontSize="11" FontWeight="Bold" Foreground="#006683"/>
                                            <TextBlock Text="/" FontSize="11" FontWeight="Bold" Foreground="#9ca3af"/>
                                            <TextBlock Text="{Binding MaxStudents}" FontSize="11" FontWeight="Bold" Foreground="#9ca3af"/>
                                        </StackPanel>
                                    </Grid>
                                    <ProgressBar Value="{Binding Progress, Mode=OneWay}" Maximum="100" Height="6" BorderThickness="0" Background="#f3f4f5" Foreground="#006683"/>
                                </StackPanel>

                                <Grid Grid.Row="4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="1.5*"/>
                                        <ColumnDefinition Width="5"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="5"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="5"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <Button Grid.Column="0" Command="{Binding DataContext.EnterClassCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}" CommandParameter="{Binding ClassId}" Height="35" Background="#0284c7" BorderThickness="0" Cursor="Hand">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border CornerRadius="8" Background="{TemplateBinding Background}">
                                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                        <TextBlock Text="&#xE8A5;" FontFamily="Segoe MDL2 Assets" Foreground="White" FontSize="14" Margin="0,0,5,0" FontWeight="Bold"/>
                                                        <TextBlock Text="Vào lớp" Foreground="White" FontSize="12" FontWeight="Bold"/>
                                                    </StackPanel>
                                                </Border>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>

                                    <Button Grid.Column="2" Command="{Binding DataContext.ManageEnrollmentCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}" CommandParameter="{Binding ClassId}" Height="35" Background="#e0f2fe" BorderThickness="0" Cursor="Hand" ToolTip="Duyệt Học Sinh">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border CornerRadius="8" Background="{TemplateBinding Background}">
                                                    <TextBlock Text="&#xE77B;" FontFamily="Segoe MDL2 Assets" Foreground="#0284c7" FontSize="14" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>

                                    <Button Grid.Column="4" Command="{Binding DataContext.EditClassCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}" CommandParameter="{Binding ClassId}" Height="35" Background="#fffbeb" BorderThickness="0" Cursor="Hand" ToolTip="Chỉnh sửa lớp">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border CornerRadius="8" Background="{TemplateBinding Background}">
                                                    <TextBlock Text="&#xE70F;" FontFamily="Segoe MDL2 Assets" Foreground="#d97706" FontSize="14" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>

                                    <Button Grid.Column="6" Command="{Binding DataContext.DeleteClassCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}" CommandParameter="{Binding ClassId}" Height="35" Background="#fef2f2" BorderThickness="0" Cursor="Hand" ToolTip="Xóa lớp">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border CornerRadius="8" Background="{TemplateBinding Background}">
                                                    <TextBlock Text="&#xE74D;" FontFamily="Segoe MDL2 Assets" Foreground="#dc2626" FontSize="14" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                </Grid>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <StackPanel Grid.Row="2">
                <TextBlock Text="Báo cáo nộp bài gần đây" FontSize="22" FontWeight="Bold" Foreground="#191c1d" Margin="0,0,0,15"/>
                <Border Background="#ffffff" CornerRadius="20" BorderBrush="#e1e3e4" BorderThickness="1" Padding="0,10,0,10">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="30" ShadowDepth="8" Color="Black" Opacity="0.03"/>
                    </Border.Effect>
                    <ItemsControl ItemsSource="{Binding RecentReports}">
                        <ItemsControl.Template>
                            <ControlTemplate TargetType="ItemsControl">
                                <StackPanel>
                                    <Grid Margin="20,10,20,15">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="2*"/>
                                            <ColumnDefinition Width="2*"/>
                                            <ColumnDefinition Width="1.5*"/>
                                            <ColumnDefinition Width="1*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="HỌC SINH" FontSize="11" FontWeight="Black" Foreground="#9ca3af"/>
                                        <TextBlock Grid.Column="1" Text="LỚP HỌC" FontSize="11" FontWeight="Black" Foreground="#9ca3af"/>
                                        <TextBlock Grid.Column="2" Text="TRẠNG THÁI" FontSize="11" FontWeight="Black" Foreground="#9ca3af"/>
                                        <TextBlock Grid.Column="3" Text="ĐIỂM SỐ" FontSize="11" FontWeight="Black" Foreground="#9ca3af"/>
                                    </Grid>
                                    <Separator Background="#f3f4f5" Margin="0,0,0,10"/>
                                    <ItemsPresenter/>
                                </StackPanel>
                            </ControlTemplate>
                        </ItemsControl.Template>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="20,10,20,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="2*"/>
                                        <ColumnDefinition Width="2*"/>
                                        <ColumnDefinition Width="1.5*"/>
                                        <ColumnDefinition Width="1*"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0" Orientation="Horizontal">
                                        <Border Width="30" Height="30" CornerRadius="15" Background="#f3f4f5" Margin="0,0,10,0">
                                            <TextBlock Text="&#xE77B;" FontFamily="Segoe MDL2 Assets" Foreground="#9ca3af" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <TextBlock Text="{Binding StudentName}" FontWeight="Bold" Foreground="#191c1d" VerticalAlignment="Center" FontSize="13"/>
                                    </StackPanel>

                                    <TextBlock Grid.Column="1" Text="{Binding CourseName}" Foreground="#6b7280" VerticalAlignment="Center" FontSize="13" FontWeight="Medium"/>

                                    <Border Grid.Column="2" HorizontalAlignment="Left" Background="{Binding StatusBgColor}" CornerRadius="10" Padding="12,5">
                                        <TextBlock Text="{Binding Status}" Foreground="{Binding StatusTextColor}" FontSize="11" FontWeight="Bold"/>
                                    </Border>

                                    <TextBlock Grid.Column="3" Text="{Binding Score}" FontWeight="Black" Foreground="#191c1d" VerticalAlignment="Center" FontSize="14"/>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Border>
            </StackPanel>
        </Grid>
    </ScrollViewer>
</UserControl>