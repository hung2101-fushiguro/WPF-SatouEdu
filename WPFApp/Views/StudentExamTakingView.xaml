<UserControl x:Class="WPFApp.Views.StudentExamTakingView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#f8f9fa" FontFamily="Segoe UI">

    <UserControl.Resources>
        <Style x:Key="RadioCardStyle" TargetType="{x:Type RadioButton}">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="#e1e3e4"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="20"/>
            <Setter Property="Margin" Value="0,0,0,10"/>

            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type RadioButton}">
                        <Border CornerRadius="12" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" Padding="{TemplateBinding Padding}" Cursor="Hand">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <Border Grid.Column="0" Width="40" Height="40" CornerRadius="8" Background="#e7e8e9" Margin="0,0,15,0">
                                    <TextBlock Text="{TemplateBinding Tag}" FontWeight="Bold" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="#191c1d"/>
                                </Border>

                                <ContentPresenter Grid.Column="1" VerticalAlignment="Center" TextElement.FontSize="16" TextElement.FontWeight="Medium"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#f3f4f5"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter Property="Background" Value="#33ccff"/>
                                <Setter Property="BorderBrush" Value="#006683"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Margin="30">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="3*"/>
            <ColumnDefinition Width="20"/>
            <ColumnDefinition Width="1*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="White" CornerRadius="15" Padding="40" BorderBrush="#e1e3e4" BorderThickness="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,30">
                    <Border Background="#e0f2fe" CornerRadius="15" Padding="15,5">
                        <TextBlock Text="{Binding CurrentQuestionIndex, StringFormat='Câu hỏi {0}'}" Foreground="#006683" FontWeight="Bold" FontSize="12" Typography.Capitals="AllSmallCaps"/>
                    </Border>
                </StackPanel>

                <TextBlock Grid.Row="1" Text="{Binding CurrentQuestion.Content}" FontSize="28" FontWeight="Black" Foreground="#191c1d" TextWrapping="Wrap" Margin="0,0,0,40"/>

                <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" Margin="0,0,0,10">
                    <StackPanel>
                        <RadioButton Tag="A" GroupName="Answers" Style="{StaticResource RadioCardStyle}" 
                                     Command="{Binding SelectAnswerCommand}" CommandParameter="A"
                                     IsChecked="{Binding CurrentQuestion.SelectedOption, Mode=OneWay}">
                            <TextBlock Text="{Binding CurrentQuestion.OptionA}" TextWrapping="Wrap"/>
                        </RadioButton>

                        <RadioButton Tag="B" GroupName="Answers" Style="{StaticResource RadioCardStyle}" 
                                     Command="{Binding SelectAnswerCommand}" CommandParameter="B"
                                     IsChecked="{Binding CurrentQuestion.SelectedOption, Mode=OneWay}">
                            <TextBlock Text="{Binding CurrentQuestion.OptionB}" TextWrapping="Wrap"/>
                        </RadioButton>

                        <RadioButton Tag="C" GroupName="Answers" Style="{StaticResource RadioCardStyle}" 
                                     Command="{Binding SelectAnswerCommand}" CommandParameter="C"
                                     IsChecked="{Binding CurrentQuestion.SelectedOption, Mode=OneWay}">
                            <TextBlock Text="{Binding CurrentQuestion.OptionC}" TextWrapping="Wrap"/>
                        </RadioButton>

                        <RadioButton Tag="D" GroupName="Answers" Style="{StaticResource RadioCardStyle}" 
                                     Command="{Binding SelectAnswerCommand}" CommandParameter="D"
                                     IsChecked="{Binding CurrentQuestion.SelectedOption, Mode=OneWay}">
                            <TextBlock Text="{Binding CurrentQuestion.OptionD}" TextWrapping="Wrap"/>
                        </RadioButton>
                    </StackPanel>
                </ScrollViewer>
                <Grid Grid.Row="3" Margin="0,30,0,0">
                    <Button Command="{Binding PrevCommand}" HorizontalAlignment="Left" Background="Transparent" BorderThickness="0" Cursor="Hand" Foreground="#5f5e5e" FontSize="16" FontWeight="Bold">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE72B;" FontFamily="Segoe MDL2 Assets" Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Câu trước" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button Command="{Binding NextCommand}" HorizontalAlignment="Right" Height="50" Padding="30,0" Background="#006683" BorderThickness="0" Cursor="Hand">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border CornerRadius="12" Background="{TemplateBinding Background}">
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <TextBlock Text="Câu tiếp theo" Foreground="White" FontSize="16" FontWeight="Bold" Margin="0,0,8,0"/>
                                        <TextBlock Text="&#xE72A;" FontFamily="Segoe MDL2 Assets" Foreground="White" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Grid>
            </Grid>
        </Border>

        <StackPanel Grid.Column="2">
            <Border Background="#f3f4f5" CornerRadius="15" Padding="30" Margin="0,0,0,20">
                <StackPanel>
                    <TextBlock Text="THỜI GIAN CÒN LẠI" FontSize="12" FontWeight="Bold" Foreground="#5f5e5e" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                    <TextBlock Text="{Binding TimeRemainingText}" FontSize="48" FontWeight="Black" Foreground="#006683" HorizontalAlignment="Center"/>
                    <ProgressBar Value="{Binding ProgressPercentage}" Height="6" Background="#e1e3e4" Foreground="#006683" BorderThickness="0" Margin="0,20,0,0"/>
                </StackPanel>
            </Border>

            <Border Background="White" CornerRadius="15" Padding="25" BorderBrush="#e1e3e4" BorderThickness="1" Margin="0,0,0,20">
                <StackPanel>
                    <TextBlock Text="Bản đồ Câu hỏi" FontSize="18" FontWeight="Bold" Margin="0,0,0,20"/>
                    <ItemsControl ItemsSource="{Binding Questions}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <UniformGrid Columns="5"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Button Command="{Binding DataContext.SelectQuestionCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}" 
                                        CommandParameter="{Binding OrderIndex}" 
                                        Content="{Binding OrderIndex}" 
                                        Background="{Binding MapColor}" Foreground="{Binding MapTextColor}" 
                                        FontWeight="Bold" FontSize="14" Margin="3" Height="45" BorderThickness="0" Cursor="Hand">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border CornerRadius="8" Background="{TemplateBinding Background}">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <Button Command="{Binding SubmitCommand}" Height="60" Background="#33ccff" BorderThickness="0" Cursor="Hand">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border CornerRadius="15" Background="{TemplateBinding Background}">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                <TextBlock Text="&#xE8FB;" FontFamily="Segoe MDL2 Assets" Foreground="#00536b" FontSize="20" Margin="0,0,10,0"/>
                                <TextBlock Text="NỘP BÀI THI" Foreground="#00536b" FontSize="18" FontWeight="Black"/>
                            </StackPanel>
                        </Border>
                    </ControlTemplate>
                </Button.Template>
            </Button>
        </StackPanel>
    </Grid>
</UserControl>