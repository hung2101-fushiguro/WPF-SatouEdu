<Window x:Class="WPFApp.Views.MainWindow" 
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" 
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" 
        xmlns:views="clr-namespace:WPFApp.Views" 
        xmlns:viewmodels="clr-namespace:WPFApp.ViewModels"
        Title="SatouEdu - Hệ thống quản lý học tập" Height="800" Width="1300" 
        WindowStartupLocation="CenterScreen" Background="#f8f9fa" 
        FontFamily="Segoe UI" WindowStyle="None" AllowsTransparency="True">

    <Window.Resources>
        <DataTemplate DataType="{x:Type viewmodels:TeacherDashboardViewModel}">
            <views:TeacherDashboardView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type viewmodels:StudentDashboardViewModel}">
            <views:StudentDashboardView/>
        </DataTemplate>

        <DataTemplate DataType="{x:Type viewmodels:QuestionBankViewModel}">
            <views:QuestionBankView/>
        </DataTemplate>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="64"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Header Bar -->
        <Border Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2" Background="#ffffff" BorderBrush="#e1e3e4" BorderThickness="0,0,0,1" Panel.ZIndex="10">
            <Border.Effect>
                <DropShadowEffect BlurRadius="10" ShadowDepth="1" Color="Black" Opacity="0.05"/>
            </Border.Effect>
            <Grid Margin="20,0,30,0">

                <!-- Khu vực bên trái: Logo + Nút Back/Forward -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center">
                    <!-- Logo SatouEdu -->
                    <Border Width="40" Height="40" CornerRadius="10" Background="#006683" Margin="0,0,15,0">
                        <TextBlock Text="&#xE82D;" FontFamily="Segoe MDL2 Assets" FontSize="20" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="SatouEdu LMS" FontSize="22" FontWeight="Black" Foreground="#191c1d" VerticalAlignment="Center"/>

                    <!-- Nút Back và Forward - Đã thêm vào đây -->
                    <StackPanel Orientation="Horizontal" Margin="30,0,0,0" VerticalAlignment="Center">
                        <Button Command="{Binding GoBackCommand}" Width="35" Height="35" Background="Transparent" BorderThickness="0" Margin="0,0,5,0" Cursor="Hand" ToolTip="Quay lại">
                            <TextBlock Text="&#xE72B;" FontFamily="Segoe MDL2 Assets" FontSize="16" Foreground="#191c1d" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Button>

                        <Button Command="{Binding GoForwardCommand}" Width="35" Height="35" Background="Transparent" BorderThickness="0" Cursor="Hand" ToolTip="Tiến lên">
                            <TextBlock Text="&#xE72A;" FontFamily="Segoe MDL2 Assets" FontSize="16" Foreground="#191c1d" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Button>
                    </StackPanel>
                </StackPanel>

                <!-- Khu vực bên phải: Tìm kiếm + Thông tin user + Thoát -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <!-- Ô tìm kiếm -->
                    <Border Background="#f3f4f5" CornerRadius="20" Height="40" Width="250" Margin="0,0,30,0" Padding="15,0,15,0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="30"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="&#xE1A3;" FontFamily="Segoe MDL2 Assets" FontSize="16" Foreground="#9ca3af" VerticalAlignment="Center"/>
                            <TextBox Grid.Column="1" Text="Tìm kiếm..." Foreground="#6b7280" Background="Transparent" BorderThickness="0" VerticalContentAlignment="Center" FontSize="13"/>
                        </Grid>
                    </Border>

                    <!-- Thông tin người dùng -->
                    <StackPanel Orientation="Horizontal" Cursor="Hand">
                        <StackPanel VerticalAlignment="Center" Margin="0,0,15,0">
                            <TextBlock Text="{Binding CurrentUser.FullName}" FontSize="14" FontWeight="Bold" Foreground="#191c1d" HorizontalAlignment="Right"/>
                            <TextBlock Text="{Binding RoleName}" FontSize="10" FontWeight="SemiBold" Foreground="#6b7280" TextAlignment="Right" Margin="0,2,0,0" TextTrimming="CharacterEllipsis" TextOptions.TextFormattingMode="Display" Typography.Capitals="AllSmallCaps"/>
                        </StackPanel>
                        <Border Width="40" Height="40" CornerRadius="20" BorderBrush="#e5e7eb" BorderThickness="2" Background="#d1d5db">
                            <TextBlock Text="&#xE77B;" FontFamily="Segoe MDL2 Assets" FontSize="20" Foreground="#4b5563" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </StackPanel>

                    <!-- Nút thoát -->
                    <Button Command="{Binding ExitCommand}" Background="Transparent" BorderThickness="0" Margin="20,0,0,0" Cursor="Hand" ToolTip="Thoát hệ thống">
                        <TextBlock Text="&#xE711;" FontFamily="Segoe MDL2 Assets" FontSize="16" Foreground="#ef4444" FontWeight="Bold"/>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Sidebar Menu -->
        <Border Grid.Row="1" Grid.Column="0" Background="#f3f4f5" Padding="20">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0">
                    <TextBlock Text="MENU" FontSize="10" FontWeight="Bold" Foreground="#9ca3af" Margin="15,0,0,15"/>

                    

                    <Button Command="{Binding NavDashboardCommand}" Visibility="{Binding TeacherMenuVisibility}" Height="45" Background="Transparent" BorderThickness="0" Margin="0,0,0,5" Cursor="Hand">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="borderBg" CornerRadius="10" Background="Transparent">
                                    <Grid>
                                        <Border x:Name="activeIndicator" Width="4" Height="20" Background="#33ccff" HorizontalAlignment="Left" CornerRadius="0,4,4,0" Visibility="Hidden"/>
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="15,0,0,0">
                                            <TextBlock x:Name="iconText" Text="&#xE909;" FontFamily="Segoe MDL2 Assets" FontSize="18" Foreground="#6b7280" Margin="0,0,15,0"/>
                                            <TextBlock x:Name="menuText" Text="Bảng điều khiển" FontSize="14" FontWeight="Medium" Foreground="#4b5563"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <DataTrigger Binding="{Binding IsDashboardActive}" Value="True">
                                        <Setter TargetName="borderBg" Property="Background" Value="#e0f2fe"/>
                                        <Setter TargetName="activeIndicator" Property="Visibility" Value="Visible"/>
                                        <Setter TargetName="iconText" Property="Foreground" Value="#0284c7"/>
                                        <Setter TargetName="menuText" Property="Foreground" Value="#0284c7"/>
                                        <Setter TargetName="menuText" Property="FontWeight" Value="Bold"/>
                                    </DataTrigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <Button Command="{Binding NavQuestionBankCommand}" Visibility="{Binding TeacherMenuVisibility}" Height="45" Background="Transparent" BorderThickness="0" Margin="0,0,0,5" Cursor="Hand">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="borderBg" CornerRadius="10" Background="Transparent">
                                    <Grid>
                                        <Border x:Name="activeIndicator" Width="4" Height="20" Background="#33ccff" HorizontalAlignment="Left" CornerRadius="0,4,4,0" Visibility="Hidden"/>
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="15,0,0,0">
                                            <TextBlock x:Name="iconText" Text="&#xE8F1;" FontFamily="Segoe MDL2 Assets" FontSize="18" Foreground="#6b7280" Margin="0,0,15,0"/>
                                            <TextBlock x:Name="menuText" Text="Ngân hàng Câu hỏi" FontSize="14" FontWeight="Medium" Foreground="#4b5563"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <DataTrigger Binding="{Binding IsQuestionBankActive}" Value="True">
                                        <Setter TargetName="borderBg" Property="Background" Value="#e0f2fe"/>
                                        <Setter TargetName="activeIndicator" Property="Visibility" Value="Visible"/>
                                        <Setter TargetName="iconText" Property="Foreground" Value="#0284c7"/>
                                        <Setter TargetName="menuText" Property="Foreground" Value="#0284c7"/>
                                        <Setter TargetName="menuText" Property="FontWeight" Value="Bold"/>
                                    </DataTrigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                    <Button Visibility="{Binding StudentMenuVisibility}" Height="45" Background="Transparent" BorderThickness="0" Margin="0,0,0,5" Cursor="Hand">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border CornerRadius="10" Background="{TemplateBinding Background}">
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="15,0,0,0">
                                        <TextBlock Text="&#xE82D;" FontFamily="Segoe MDL2 Assets" FontSize="18" Foreground="#6b7280" Margin="0,0,15,0"/>
                                        <TextBlock Text="Lớp học của tôi" FontSize="14" FontWeight="Medium" Foreground="#4b5563"/>
                                    </StackPanel>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </StackPanel>

                <Border Grid.Row="2" BorderBrush="#e1e3e4" BorderThickness="0,1,0,0" Padding="0,15,0,0">
                    <Button Command="{Binding LogoutCommand}" Height="45" Background="Transparent" BorderThickness="0" Cursor="Hand" ToolTip="Đăng xuất khỏi hệ thống">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="borderBg" CornerRadius="10" Background="{TemplateBinding Background}">
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="15,0,0,0">
                                        <TextBlock Text="&#xE748;" FontFamily="Segoe MDL2 Assets" FontSize="18" Foreground="#ef4444" Margin="0,0,15,0"/>
                                        <TextBlock Text="Đăng xuất" FontSize="14" FontWeight="SemiBold" Foreground="Red"/>
                                    </StackPanel>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="borderBg" Property="Background" Value="#fee2e2"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Border>
            </Grid>
        </Border>

        <!-- Content Area -->
        <ContentControl Grid.Row="1" Grid.Column="1" Content="{Binding CurrentView}" Margin="20"/>
    </Grid>
</Window>