<Window x:Class="WPFApp.Views.AddEditQuestionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{Binding TitleText}" Height="600" Width="600"
        WindowStartupLocation="CenterScreen" Background="#f8f9fa" FontFamily="Segoe UI">
    <Grid Margin="20">
        <Border Background="White" CornerRadius="10" Padding="25" BorderBrush="#e1e3e4" BorderThickness="1">
            <StackPanel>
                <TextBlock Text="{Binding TitleText}" FontSize="24" FontWeight="Black" Margin="0,0,0,20" Foreground="#006683"/>

                <TextBlock Text="Nội dung câu hỏi:" FontWeight="Bold" Margin="0,0,0,5"/>
                <TextBox Text="{Binding Content}" Height="80" TextWrapping="Wrap" AcceptsReturn="True" Background="#f3f4f5" Margin="0,0,0,15" Padding="5"/>

                <Grid Margin="0,0,0,15">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="15"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Đáp án A:" FontWeight="Bold" Margin="0,0,0,5" Foreground="#16a34a"/>
                        <TextBox Text="{Binding OptionA}" Height="35" Background="#f0fdf4" Padding="5"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Đáp án B:" FontWeight="Bold" Margin="0,0,0,5" Foreground="#2563eb"/>
                        <TextBox Text="{Binding OptionB}" Height="35" Background="#eff6ff" Padding="5"/>
                    </StackPanel>
                </Grid>

                <Grid Margin="0,0,0,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="15"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Đáp án C:" FontWeight="Bold" Margin="0,0,0,5" Foreground="#d97706"/>
                        <TextBox Text="{Binding OptionC}" Height="35" Background="#fffbeb" Padding="5"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Đáp án D:" FontWeight="Bold" Margin="0,0,0,5" Foreground="#dc2626"/>
                        <TextBox Text="{Binding OptionD}" Height="35" Background="#fef2f2" Padding="5"/>
                    </StackPanel>
                </Grid>

                <StackPanel Orientation="Horizontal" Margin="0,0,0,30" VerticalAlignment="Center">
                    <TextBlock Text="ĐÁP ÁN ĐÚNG:" FontWeight="Black" FontSize="16" VerticalAlignment="Center" Margin="0,0,15,0"/>
                    <ComboBox ItemsSource="{Binding CorrectOptionsList}" SelectedItem="{Binding SelectedCorrectOption}" Width="100" Height="40" FontSize="16" FontWeight="Bold" VerticalContentAlignment="Center" HorizontalContentAlignment="Center"/>
                </StackPanel>

                <Button Command="{Binding SaveCommand}" Height="45" Background="#00FFFF" BorderThickness="0" Cursor="Hand">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border CornerRadius="8" Background="{TemplateBinding Background}">
                                <TextBlock Text="Lưu Câu Hỏi" Foreground="White" FontSize="16" FontWeight="Bold" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </StackPanel>
        </Border>
    </Grid>
</Window>