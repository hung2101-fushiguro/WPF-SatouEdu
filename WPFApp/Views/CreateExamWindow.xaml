<Window x:Class="WPFApp.Views.CreateExamWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Tạo Bài Tập / Kiểm Tra" Height="650" Width="900"
        WindowStartupLocation="CenterScreen" Background="#f8f9fa" FontFamily="Segoe UI">

    <Grid Margin="20">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="350"/>
            <ColumnDefinition Width="20"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="White" CornerRadius="10" Padding="20">
            <StackPanel>
                <TextBlock Text="Cài đặt Bài thi" FontSize="20" FontWeight="Black" Margin="0,0,0,20"/>

                <TextBlock Text="Tên bài kiểm tra/bài tập" FontWeight="Bold" Margin="0,0,0,5"/>
                <TextBox Text="{Binding ExamName}" Height="35" Background="#f3f4f5" Margin="0,0,0,15" Padding="5"/>

                <TextBlock Text="Loại hình" FontWeight="Bold" Margin="0,0,0,5"/>
                <ComboBox SelectedIndex="{Binding ExamType}" Height="35" Margin="0,0,0,15">
                    <ComboBoxItem Content="Chọn loại... (Bỏ qua)"/>
                    <ComboBoxItem Content="Bài tập về nhà"/>
                    <ComboBoxItem Content="Bài kiểm tra"/>
                </ComboBox>

                <Grid Margin="0,0,0,15">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Mở bài từ ngày" FontWeight="Bold" Margin="0,0,0,5"/>
                        <DatePicker SelectedDate="{Binding StartDate}" Height="35"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Hạn chót (Deadline)" FontWeight="Bold" Margin="0,0,0,5"/>
                        <DatePicker SelectedDate="{Binding EndDate}" Height="35"/>
                    </StackPanel>
                </Grid>

                <TextBlock Text="Thời gian làm bài (Phút)" FontWeight="Bold" Margin="0,0,0,5"/>
                <TextBox Text="{Binding DurationMinutes}" Height="35" Background="#f3f4f5" Margin="0,0,0,15" Padding="5"/>

                <CheckBox IsChecked="{Binding IsScoreVisible}" Content="Hiển thị điểm ngay sau khi nộp" FontWeight="Bold" Margin="0,0,0,20"/>

                <Button Command="{Binding SaveExamCommand}" Height="45" Background="#006683" Foreground="White" FontWeight="Bold" Cursor="Hand" Content="Lưu &amp; Xuất bản"/>
            </StackPanel>
        </Border>

        <Border Grid.Column="2" Background="White" CornerRadius="10" Padding="20">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Margin="0,0,0,15">
                    <TextBlock Text="Chọn câu hỏi từ Ngân hàng" FontSize="20" FontWeight="Black"/>

                    <Grid Margin="0,10,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Hệ thống đã tự động lọc câu hỏi theo môn của lớp." Foreground="#6b7280" VerticalAlignment="Center" TextWrapping="Wrap"/>

                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="Khối lớp:" FontWeight="Bold" Margin="0,0,10,0" VerticalAlignment="Center"/>
                            <ComboBox ItemsSource="{Binding AvailableGrades}" SelectedItem="{Binding SelectedGradeLevel}" Width="80" Height="30" VerticalContentAlignment="Center"/>
                        </StackPanel>
                    </Grid>

                    <Border Background="#f0fdf4" BorderBrush="#bbf7d0" BorderThickness="1" CornerRadius="8" Padding="15" Margin="0,15,0,0">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="&#xE72C;" FontFamily="Segoe MDL2 Assets" Foreground="#16a34a" FontSize="18" Margin="0,0,10,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Chọn ngẫu nhiên:" FontWeight="Bold" Foreground="#166534" VerticalAlignment="Center" Margin="0,0,10,0"/>
                            <TextBox Text="{Binding RandomQuestionCount}" Width="50" Height="30" VerticalContentAlignment="Center" HorizontalContentAlignment="Center" Margin="0,0,10,0" ToolTip="Nhập số câu"/>
                            <TextBlock Text="câu hỏi" Foreground="#166534" VerticalAlignment="Center" Margin="0,0,15,0"/>

                            <Button Command="{Binding RandomSelectCommand}" Height="30" Padding="15,0" Background="#22c55e" BorderThickness="0" Cursor="Hand">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border CornerRadius="6" Background="{TemplateBinding Background}">
                                            <TextBlock Text="Random Ngay" Foreground="White" FontWeight="Bold" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding AvailableQuestions}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="#e1e3e4" BorderThickness="1" CornerRadius="8" Margin="0,0,0,10" Padding="15">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <CheckBox Grid.Column="0" IsChecked="{Binding IsSelected}" VerticalAlignment="Center" Margin="0,0,15,0">
                                            <CheckBox.LayoutTransform>
                                                <ScaleTransform ScaleX="1.5" ScaleY="1.5"/>
                                            </CheckBox.LayoutTransform>
                                        </CheckBox>

                                        <TextBlock Grid.Column="1" Text="{Binding Content}" TextWrapping="Wrap" FontSize="14" VerticalAlignment="Center"/>

                                        <Border Grid.Column="2" Background="#f3f4f5" CornerRadius="5" Padding="8,4" Margin="10,0,0,0" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding GradeLevel, StringFormat='Lớp {0}'}" FontSize="11" FontWeight="Bold" Foreground="#6b7280"/>
                                        </Border>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Border>
    </Grid>
</Window>