<Window x:Class="WPFApp.Views.StudentClassDetailWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:viewmodels="clr-namespace:WPFApp.ViewModels"
        xmlns:views="clr-namespace:WPFApp.Views"
        Title="{Binding ClassName, StringFormat='Lớp: {0}'}" 
        Height="700" 
        Width="1000"
        WindowStartupLocation="CenterScreen" 
        Background="#f8f9fa" 
        FontFamily="Segoe UI">

    <!-- DataTemplate để tự động hiển thị StudentExamTakingView khi ActiveExamVM thay đổi -->
    <Window.Resources>
        <DataTemplate DataType="{x:Type viewmodels:StudentExamTakingViewModel}">
            <views:StudentExamTakingView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type viewmodels:StudentExamResultViewModel}">
            <views:StudentExamResultView/>
        </DataTemplate>
    </Window.Resources>

    <Grid>
        <!-- Phần 1: Danh sách thông tin lớp học và bài tập -->
        <Grid Margin="30" Visibility="{Binding ListVisibility}">

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Thông tin lớp học -->
            <Border Grid.Row="0" 
                    Background="White" 
                    CornerRadius="15" 
                    Padding="25" 
                    Margin="0,0,0,25">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="15" ShadowDepth="2" Color="Black" Opacity="0.03"/>
                </Border.Effect>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="{Binding ClassName}" 
                                   FontSize="32" 
                                   FontWeight="Black" 
                                   Foreground="#006683" 
                                   Margin="0,0,0,5"/>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                            <TextBlock Text="&#xE77B;" 
                                       FontFamily="Segoe MDL2 Assets" 
                                       Foreground="#6b7280" 
                                       FontSize="16" 
                                       Margin="0,0,8,0" 
                                       VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding TeacherName}" 
                                       FontSize="16" 
                                       FontWeight="SemiBold" 
                                       Foreground="#3d484e" 
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                        <TextBlock Text="{Binding Description}" 
                                   FontSize="14" 
                                   Foreground="#6b7280" 
                                   TextWrapping="Wrap"/>
                    </StackPanel>

                    <Border Grid.Column="1" 
                            Width="80" 
                            Height="80" 
                            CornerRadius="40" 
                            Background="#e0f2fe" 
                            HorizontalAlignment="Right">
                        <TextBlock Text="&#xE8D3;" 
                                   FontFamily="Segoe MDL2 Assets" 
                                   FontSize="36" 
                                   Foreground="#006683" 
                                   HorizontalAlignment="Center" 
                                   VerticalAlignment="Center"/>
                    </Border>
                </Grid>
            </Border>

            <!-- Danh sách Bài tập & Kiểm tra -->
            <Grid Grid.Row="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" 
                           Text="Danh sách Bài tập &amp; Kiểm tra" 
                           FontSize="20" 
                           FontWeight="Bold" 
                           Foreground="#191c1d" 
                           Margin="0,0,0,15"/>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding ExamsList}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="White" 
                                        BorderBrush="#e1e3e4" 
                                        BorderThickness="1" 
                                        CornerRadius="12" 
                                        Padding="20" 
                                        Margin="0,0,0,15">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding ExamName}" 
                                                       FontSize="18" 
                                                       FontWeight="Bold" 
                                                       Foreground="#191c1d" 
                                                       Margin="0,0,0,8"/>
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="&#xE916;" 
                                                           FontFamily="Segoe MDL2 Assets" 
                                                           Foreground="#6b7280" 
                                                           FontSize="14" 
                                                           Margin="0,0,5,0" 
                                                           VerticalAlignment="Center"/>
                                                <TextBlock Text="{Binding DurationMinutes, StringFormat='Thời gian: {0} phút'}" 
                                                           Foreground="#6b7280" 
                                                           FontSize="13" 
                                                           Margin="0,0,20,0" 
                                                           VerticalAlignment="Center"/>

                                                <TextBlock Text="&#xE125;" 
                                                           FontFamily="Segoe MDL2 Assets" 
                                                           Foreground="#dc2626" 
                                                           FontSize="14" 
                                                           Margin="0,0,5,0" 
                                                           VerticalAlignment="Center"/>
                                                <TextBlock Text="{Binding EndTimeText, StringFormat='Hạn chót: {0}'}" 
                                                           Foreground="#dc2626" 
                                                           FontSize="13" 
                                                           FontWeight="SemiBold" 
                                                           VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </StackPanel>

                                        <Border Grid.Column="1" 
                                                Background="{Binding StatusColor}" 
                                                CornerRadius="20" 
                                                Padding="15,5" 
                                                Margin="0,0,20,0" 
                                                VerticalAlignment="Center">
                                            <TextBlock Text="{Binding StatusText}" 
                                                       FontSize="12" 
                                                       FontWeight="Bold" 
                                                       Foreground="White"/>
                                        </Border>

                                        <Button Grid.Column="2" 
                                                Command="{Binding DataContext.OpenExamCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}" 
                                                CommandParameter="{Binding ExamId}" 
                                                Height="40" 
                                                Padding="20,0" 
                                                Background="{Binding ActionButtonColor}" 
                                                BorderThickness="0" 
                                                Cursor="Hand" 
                                                VerticalAlignment="Center">
                                            <Button.Template>
                                                <ControlTemplate TargetType="Button">
                                                    <Border CornerRadius="8" Background="{TemplateBinding Background}">
                                                        <TextBlock Text="{Binding ActionButtonText}" 
                                                                   Foreground="White" 
                                                                   FontWeight="Bold" 
                                                                   FontSize="14" 
                                                                   VerticalAlignment="Center" 
                                                                   HorizontalAlignment="Center"/>
                                                    </Border>
                                                </ControlTemplate>
                                            </Button.Template>
                                        </Button>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Grid>

        <!-- Phần 2: Màn hình làm bài thi (Sân khấu thứ 2) -->
        <ContentControl Content="{Binding ActiveExamVM}" 
                        Visibility="{Binding ExamVisibility}"/>
    </Grid>
</Window>