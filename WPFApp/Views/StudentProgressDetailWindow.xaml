<Window x:Class="WPFApp.Views.StudentProgressDetailWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Chi tiết điểm số" Height="500" Width="600"
        WindowStartupLocation="CenterOwner" Background="#f8f9fa" FontFamily="Segoe UI">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock x:Name="txtTitle" Grid.Row="0" FontSize="20" FontWeight="Bold" Foreground="#006683" Margin="0,0,0,15"/>

        <Border Grid.Row="1" Background="White" CornerRadius="10" BorderBrush="#e1e3e4" BorderThickness="1" Padding="15">
            <DataGrid x:Name="dgProgress" AutoGenerateColumns="False" IsReadOnly="True" Background="White" BorderThickness="0" HeadersVisibility="Column">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Tên bài tập / Kiểm tra" Binding="{Binding ExamName}" Width="*"/>
                    <DataGridTextColumn Header="Trạng thái" Binding="{Binding StatusText}" Width="100"/>
                    <DataGridTextColumn Header="Điểm số" Binding="{Binding ScoreText}" Width="80">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="FontWeight" Value="Bold"/>
                                <Setter Property="Foreground" Value="#16a34a"/>
                                <Setter Property="HorizontalAlignment" Value="Center"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</Window>